<Window x:Class="LanTransferPC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LanTransferPC"
        mc:Ignorable="d"
    Title="局域网互联 PC端" Height="450" Width="700" WindowStartupLocation="CenterScreen"
        AllowDrop="True" Drop="Window_Drop" KeyDown="Window_KeyDown">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="200" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ListBox x:Name="lstMessages" Grid.Row="0" Margin="0,0,0,10" 
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBox Text="{Binding Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" 
                 BorderThickness="0" Background="Transparent" 
                 SelectionBrush="#4CAF50" Margin="0,2"/>
                        <!--<TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,2"/>-->
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel x:Name="panelProgress" Grid.Row="0" VerticalAlignment="Bottom" Background="#F0F0F0" Visibility="Collapsed" Margin="5" >
                <TextBlock x:Name="txtProgress" Text="正在传输: 0%" FontWeight="Bold" Margin="0,0,0,5"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ProgressBar x:Name="pbTransfer" Grid.Column="0" Height="15" Minimum="0" Maximum="100"/>
                    <Button Grid.Column="1" Content="取消" Width="50" Margin="5,0,0,0" Background="#F44336" Foreground="White" BorderThickness="0" Click="BtnCancelTransfer_Click"/>
                </Grid>
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button x:Name="btnAddFile" Grid.Column="0" Content="+" Width="30" Height="30" 
                        FontSize="18" FontWeight="Bold" Click="BtnAddFile_Click" ToolTip="选择文件"/>

                <TextBox x:Name="txtInput" Grid.Column="1" Margin="5,0" Height="30" 
                         VerticalContentAlignment="Center" KeyDown="TxtInput_KeyDown"/>

                <Button x:Name="btnSend" Grid.Column="2" Content="发送" Width="60" Height="30" 
                        Click="BtnSend_Click"/>
            </Grid>
        </Grid>

        <Rectangle Grid.Column="1" Fill="#DDDDDD" />

        <StackPanel Grid.Column="2" Margin="10">
            <TextBlock Text="服务设置" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

            <TextBlock Text="监听端口:" Margin="0,0,0,5"/>
            <TextBox x:Name="txtPort" Text="8888" Height="25" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock Text="文件接收路径:" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtSavePath" Grid.Column="0" Height="25" VerticalContentAlignment="Center" IsReadOnly="True"/>
                <Button x:Name="btnSelectPath" Grid.Column="1" Content="..." Width="25" Height="25" Margin="5,0,0,0" Click="BtnSelectPath_Click" ToolTip="选择文件夹"/>
                <Button x:Name="btnOpenPath" Grid.Column="2" Content="浏览" Width="40" Height="25" Margin="5,0,0,0" Click="BtnOpenPath_Click" ToolTip="打开文件夹"/>
            </Grid>

            <Button x:Name="btnToggleService" Content="开启服务" Height="35" 
            Background="#4CAF50" Foreground="White" BorderThickness="0"
            Click="BtnToggleService_Click"/>

            <TextBlock x:Name="txtStatus" Text="状态: 未开启" Foreground="Gray" Margin="0,15,0,0"/>
        </StackPanel>
    </Grid>
</Window>
