<Window x:Class="CodexApiProxy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CodexApiProxy"
        mc:Ignorable="d"
        Title="Codex API Proxy" Height="550" Width="650"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="配置" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="API 地址:" VerticalAlignment="Center" Margin="0,0,0,8"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtApiUrl" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="API Key:" VerticalAlignment="Center" Margin="0,0,0,8"/>
                <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="txtApiKey" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="模型:" VerticalAlignment="Center" Margin="0,0,0,8"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtModel" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="端口:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtPort"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1" Header="代理地址" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock x:Name="txtProxyUrl" FontSize="14" FontWeight="Bold" Foreground="#0066CC"/>
                <TextBlock Text="在 CCSwitch 中填写此地址" FontSize="11" Foreground="Gray" Margin="0,4,0,0"/>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <Button x:Name="btnStart" Content="启动服务" Width="100" Height="35" Margin="0,0,10,0" Click="BtnStart_Click"/>
            <Button x:Name="btnStop" Content="停止服务" Width="100" Height="35" IsEnabled="False" Click="BtnStop_Click"/>
            <Button x:Name="btnSave" Content="保存配置" Width="100" Height="35" Margin="10,0,0,0" Click="BtnSave_Click"/>
        </StackPanel>

        <GroupBox Grid.Row="3" Header="日志" Padding="5">
            <TextBox x:Name="txtLog" IsReadOnly="True" VerticalScrollBarVisibility="Auto" 
                     HorizontalScrollBarVisibility="Auto" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
        </GroupBox>

        <StatusBar Grid.Row="4" Margin="0,5,0,0">
            <TextBlock x:Name="txtStatus" Text="就绪"/>
        </StatusBar>
    </Grid>
</Window>
