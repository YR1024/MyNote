<Window x:Class="ScheduleReminder.NotifyWnd"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ScheduleReminder"
        mc:Ignorable="d"
    Title="NotifyWindow" Height="210" Width="345" ResizeMode="NoResize"
        ShowInTaskbar="False"  WindowStyle="ToolWindow"
        x:Name="window">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" CornerRadius="5" ResizeBorderThickness="6" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Grid Margin="0" Background="Transparent">
        <!--<Image Source="../../Resources/NewMainView/底图.png"  RenderOptions.BitmapScalingMode="HighQuality"  Stretch="None" />-->

        <Grid Background="Transparent">
            <Button Content="关闭" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="5" Click="Close_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="close" Text="{TemplateBinding Content}" ToolTip="{TemplateBinding Content}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="close" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90*"/>
                    <ColumnDefinition Width="259*"/>
                </Grid.ColumnDefinitions>
                <Grid Width="30" Height="30" HorizontalAlignment="Right">
                    <Path Stretch="Fill" Fill="#d81e06"  StrokeThickness="1" Stroke="Transparent">
                        <Path.Data>
                            M512 928a416 416 0 1 0 0-832 416 416 0 0 0 0 832z m0 96A512 512 0 1 1 512 0a512 512 0 0 1 0 1024z
                        M562.112 295.36v288q0 48-48 48t-48-48v-288q0-48 48-48t48 48zM450.048 743.488a64 64 0 1 0 128 0 64 64 0 1 0-128 0z
                            <!--M466.112 294.784a48 48 0 0 1 96 0V583.68a48 48 0 0 1-96 0V294.784z-->
                        </Path.Data>
                    </Path>
                </Grid>
                <TextBlock Grid.Column="1" x:Name="msg"  Text="" FontSize="20" HorizontalAlignment="Left" Margin="20 0 0 0" VerticalAlignment="Center" TextWrapping="Wrap"/>
            </Grid>
        </Grid>
    </Grid>
</Window>

