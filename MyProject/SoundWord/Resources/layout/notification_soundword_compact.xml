<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingEnd="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/notification_title"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:text="SoundWord"
            android:textColor="#111827"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/notification_content"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1.5"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:text="正在翻译系统声音"
            android:textColor="#475569"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:layout_marginTop="4dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/action_font_down"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/notification_button"
            android:gravity="center"
            android:text="字-"
            android:textColor="#0F172A"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/action_font_up"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/notification_button"
            android:gravity="center"
            android:text="字+"
            android:textColor="#0F172A"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/action_opacity_down"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/notification_button"
            android:gravity="center"
            android:text="淡"
            android:textColor="#0F172A"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/action_opacity_up"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/notification_button"
            android:gravity="center"
            android:text="深"
            android:textColor="#0F172A"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/action_lock"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/notification_button_primary"
            android:gravity="center"
            android:text="锁"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/action_stop"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/notification_button_danger"
            android:gravity="center"
            android:text="停"
            android:textColor="#991B1B"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
