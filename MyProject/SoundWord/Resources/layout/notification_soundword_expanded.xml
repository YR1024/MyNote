<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="116dp"
    android:orientation="vertical"
    android:paddingStart="10dp"
    android:paddingTop="8dp"
    android:paddingEnd="10dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/notification_title"
        android:layout_width="match_parent"
        android:layout_height="22dp"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:maxLines="1"
        android:text="SoundWord 实时字幕"
        android:textColor="#111827"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/notification_content"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:maxLines="1"
        android:text="正在翻译系统声音"
        android:textColor="#475569"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/action_font_down"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/notification_button"
            android:gravity="center"
            android:text="字-"
            android:textColor="#0F172A"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/action_font_up"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/notification_button"
            android:gravity="center"
            android:text="字+"
            android:textColor="#0F172A"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/action_opacity_down"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/notification_button"
            android:gravity="center"
            android:text="淡"
            android:textColor="#0F172A"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/action_opacity_up"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/notification_button"
            android:gravity="center"
            android:text="深"
            android:textColor="#0F172A"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/action_lock"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/notification_button_primary"
            android:gravity="center"
            android:text="锁定"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/action_stop"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/notification_button_danger"
            android:gravity="center"
            android:text="停止"
            android:textColor="#991B1B"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
