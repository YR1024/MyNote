<Window x:Class="SkipDrama_YuanShen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SkipDrama_YuanShen"
        mc:Ignorable="d"
           Title="MainWindow" Height="300" Width="230">
  
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="快捷键：Ctrl + ?/" FontSize="16" Margin="0 0 0 20"/>
            <TextBlock FontSize="14">
                <Run Text="当前任务状态："/>
                <Run x:Name="info" FontSize="16" FontWeight="Bold" Text="暂停"/>
                <Run x:Name="count" Text=""/>
            </TextBlock>
            <CheckBox x:Name="screenshotChkBox" Content="左键截图" Margin="0 20"/>
            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="doubleMaTou" Content="火神双码头" ToolTip="Ctrl+ ," Margin="0 10" Checked="MTNB1_Checked" Unchecked="MTNB1_UnChecked"/>
                <CheckBox x:Name="doubleMaTou_CP" Content="藏劈" ToolTip="Ctrl+ ." Margin="20 10" Checked="MTNB2_Checked"  Unchecked="MTNB2_UnChecked">
                   
                </CheckBox>
            </StackPanel>
         
        </StackPanel>
    </Grid>
</Window>
