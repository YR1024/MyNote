<Window x:Class="SkipDrama_YuanShen.SdlMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="原神手柄助手 (SDL3)"
        Width="420"
        Height="390"
        MinWidth="420"
        MinHeight="390"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="20" FontWeight="Bold" Text="原神手柄助手" />

        <Border Grid.Row="1" Margin="0,14,0,0" Padding="12" Background="#FFF4F4F4" CornerRadius="5">
            <StackPanel>
                <TextBlock TextWrapping="Wrap">
                    <Run Text="输入设备：" />
                    <Run x:Name="DeviceText" FontWeight="SemiBold" Text="正在初始化 SDL3..." />
                </TextBlock>
                <TextBlock Margin="0,6,0,0" TextWrapping="Wrap">
                    <Run Text="运行状态：" />
                    <Run x:Name="StatusText" FontWeight="SemiBold" Text="正在启动" />
                    <Run x:Name="CountText" />
                </TextBlock>
                <TextBlock Margin="0,6,0,0" TextWrapping="Wrap">
                    <Run Text="最近输入：" />
                    <Run x:Name="LastInputText" Text="-" />
                </TextBlock>
            </StackPanel>
        </Border>

        <GroupBox Grid.Row="2" Margin="0,14,0,0" Header="快捷操作">
            <StackPanel Margin="10,6">
                <TextBlock Text="Ctrl + /：切换 A 连点；手柄 LT + X 按住 50ms：切换 A 连点" TextWrapping="Wrap" />
                <TextBlock Margin="0,5,0,0" Text="Ctrl + ,：切换火神跳劈；Ctrl + .：切换藏劈" TextWrapping="Wrap" />
                <TextBlock Margin="0,5,0,0" Foreground="#FF666666" Text="宏只在原神成为前台窗口时输出。" />
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="3" Margin="0,12,0,0" Header="LT 按住宏">
            <StackPanel Margin="10,6" Orientation="Horizontal">
                <CheckBox x:Name="JumpPlungeCheckBox" Content="火神跳劈" Checked="JumpPlunge_Checked" Unchecked="JumpPlunge_Unchecked" />
                <CheckBox x:Name="HiddenPlungeCheckBox" Margin="24,0,0,0" Content="藏劈" Checked="HiddenPlunge_Checked" Unchecked="HiddenPlunge_Unchecked" />
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="4" Margin="0,12,0,0" Header="截图">
            <StackPanel Margin="10,6">
                <CheckBox x:Name="ShareScreenshotCheckBox" Content="Share 键 -> NVIDIA App Alt+F1" IsChecked="True" Checked="ScreenshotOption_Changed" Unchecked="ScreenshotOption_Changed" />
                <CheckBox x:Name="LeftScreenshotCheckBox" Margin="0,7,0,0" Content="方向键左 -> 程序直接截图 (UU远程)" IsChecked="True" Checked="ScreenshotOption_Changed" Unchecked="ScreenshotOption_Changed" />
            </StackPanel>
        </GroupBox>

        <TextBlock Grid.Row="5" x:Name="ErrorText" Margin="0,14,0,0" Foreground="#FFB00020" TextWrapping="Wrap" />
    </Grid>
</Window>
